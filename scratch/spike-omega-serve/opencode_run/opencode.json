{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "ensemble": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ensemble Spike (llm-orc)",
      "options": {
        "baseURL": "http://127.0.0.1:8099/v1",
        "apiKey": "sk-noauth-local-spike"
      },
      "models": {
        "ensemble-agent": {
          "name": "ensemble-agent (llm-orc serve)"
        }
      }
    }
  },
  "permission": {
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "edit": "allow",
    "lsp": "allow",
    "bash": "deny",
    "webfetch": "deny",
    "websearch": "deny",
    "task": "deny",
    "skill": "deny",
    "external_directory": "deny",
    "question": "deny",
    "doom_loop": "deny"
  }
}
