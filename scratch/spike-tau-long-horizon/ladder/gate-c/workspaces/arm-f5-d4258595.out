 degrees Fahrenheit.\n        \n    Returns:","truncated":false,"loaded":[]},"title":"scratch/spike-tau-long-horizon/ladder/gate-c/workspaces/arm-f5-d4258595/converters.py","time":{"start":1781714334846,"end":1781714334852}},"id":"prt_ed6733477001mgQhfqBFKGKUu8","sessionID":"ses_1298e5ed2ffeaekxa42UqD0CQE","messageID":"msg_ed6731a03001TwU7Ui2BKrIykV"}}
